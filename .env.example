# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Gemini AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Apple Calendar (iCloud CalDAV) ────────────────────────────────────────────
# Your Apple ID email address
APPLE_ID=your_apple_id@icloud.com
# App-Specific Password — generate one at https://appleid.apple.com
# Go to: Sign-In & Security → App-Specific Passwords → Generate
APPLE_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Google Drive (for Trunk file storage) ─────────────────────────────────────
# Service account JSON — either as a file path OR base64-encoded JSON string
GOOGLE_JSON=
GOOGLE_DRIVE_FOLDER_ID=

# ── Bot settings ──────────────────────────────────────────────────────────────
# Default timezone for all users (can be overridden per user via /settings)
DEFAULT_TIMEZONE=Asia/Kolkata
# Default daily briefing time (HH:MM in 24h, local to user timezone)
DEFAULT_BRIEFING_TIME=07:00
# SQLite database file path
DB_PATH=memorae.db
